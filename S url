from django.urls import path

from .views import (
    StoryListView,
    StoryCreateView,
    StoryDetailView,
    StoryDeleteView,
)

app_name = "stories"

urlpatterns = [

    path(
        "",
        StoryListView.as_view(),
        name="story_list"
    ),

    path(
        "create/",
        StoryCreateView.as_view(),
        name="story_create"
    ),

    path(
        "<int:pk>/",
        StoryDetailView.as_view(),
        name="story_detail"
    ),

    path(
        "<int:pk>/delete/",
        StoryDeleteView.as_view(),
        name="story_delete"
    ),

]
